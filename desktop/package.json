{
  "name": "vibrary-desktop",
  "version": "0.1.0",
  "private": true,
  "productName": "Vibrary",
  "description": "Windows desktop shell for the Vibrary local library server.",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.node.json && vite build",
    "dist:portable": "npm run build && electron-builder --win portable",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "build": {
    "appId": "com.vibrary.desktop",
    "productName": "Vibrary",
    "asar": true,
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "sidecars",
        "to": "sidecars",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
